{
  "name": "agentic-ecommerce",
  "version": "1.0.0",
  "private": true,
  "description": "AI-native multi-tenant ecommerce SaaS platform",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "build": "pnpm -r --filter './packages/*' run build && pnpm --filter backend build && pnpm --filter frontend build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "seed": "pnpm --filter backend seed",
    "migrate:products": "pnpm --filter backend migrate:products",
    "lint": "pnpm -r lint",
    "start": "concurrently \"API_PORT=4000 pnpm --filter backend start\" \"PORT=3000 HOSTNAME=0.0.0.0 pnpm --filter frontend start\""
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
